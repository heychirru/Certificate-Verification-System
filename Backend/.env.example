# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Connection string (Atlas or local). Required for the API and seed:admin script.
MONGO_URI=mongodb://127.0.0.1:27017/certificate-verification

# ─── JWT access token ───────────────────────────────────────────────────────────
# Use long random strings in production (e.g. openssl rand -hex 64).
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m

# ─── JWT refresh token ──────────────────────────────────────────────────────────
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin(s) are validated in app.js; trailing slashes are stripped.
# Example for Vite: http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Optional: seed first admin (npm run seed:admin) ─────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
# Must satisfy User model rules (min 8 chars); match API register rules if you reuse the same password elsewhere.
SEED_ADMIN_PASSWORD=Adminpass1!
SEED_ADMIN_NAME=Admin

# ─── Email Configuration (Gmail SMTP) ─────────────────────────────────────────
# Generate Gmail App Password: https://myaccount.google.com/apppasswords
# IMPORTANT: Remove all spaces from the App Password (Google displays with spaces for readability)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# ─── Organization ───────────────────────────────────────────────────────────────
ORGANIZATION_NAME=Amdox Technologies
